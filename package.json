{
  "name": "texas-gto-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "serve": "node server/index.js",
    "dev:stable": "tmux has-session -t texas-gto-lab 2>/dev/null || tmux new-session -d -s texas-gto-lab -c \"$PWD\" 'npm run build && HOST=127.0.0.1 PORT=5174 npm run serve'",
    "dev:stop": "tmux kill-session -t texas-gto-lab",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node test/engine.test.js && node test/strategy-audit.test.js",
    "test:strategy-audit": "node test/strategy-audit.test.js",
    "test:solver": "python3 scripts/solver/river_cfr.py --self-test && python3 scripts/solver/turn_cfr.py --self-test && python3 scripts/solver/solver_torch.py --self-test && python3 scripts/solver/turn_torch.py --self-test",
    "train:policy": "python3 scripts/train-policy.py",
    "solve:river": "python3 scripts/solver/river_cfr.py",
    "solve:turn": "python3 scripts/solver/turn_cfr.py",
    "solve:gpu": "python3 scripts/solver/solver_torch.py",
    "solve:gpu-turn": "python3 scripts/solver/turn_torch.py",
    "solve:flop": "python3 scripts/solver/flop_mccfr.py",
    "test:solver-flop": "python3 scripts/solver/flop_mccfr.py --self-test",
    "measure:engine": "python3 scripts/solver/engine_exploitability.py",
    "export:solved": "python3 scripts/solver/export_solved.py",
    "gen:dataset": "python3 scripts/solver/gen_solved_dataset.py",
    "train:distill": "python3 scripts/solver/train_distill.py"
  },
  "dependencies": {
    "lucide": "^1.21.0",
    "pokersolver": "^2.1.4",
    "vite": "^8.0.16",
    "ws": "^8.21.0"
  }
}
